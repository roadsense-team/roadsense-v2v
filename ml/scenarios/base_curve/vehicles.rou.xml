<routes>
  <!-- Single-lane convoy: no lane changes, no overtaking -->
  <vType id="car" accel="2.6" decel="10.0" emergencyDecel="20.0" sigma="0.0" length="5" maxSpeed="50"
         tau="1.000" speedFactor="1.0" speedDev="0"
         lcStrategic="0.0" lcCooperative="0.0" lcSpeedGain="0.0" lcKeepRight="0.0">
    <param key="has.ssm.device" value="true" />
    <param key="device.ssm.measures" value="TTC DRAC PET" />
    <param key="device.ssm.thresholds" value="4.0 3.4 2.0" />
    <param key="device.ssm.range" value="100.0" />
    <param key="device.ssm.file" value="ssm_output.xml" />
  </vType>

  <!-- Route: all 3 segments of Road 784, north to south through the hairpin curve -->
  <route id="convoy_route" edges="636924784#0 636924784#1 636924784#2" />

  <!-- === Blind Curve V2V Warning Scenario (3-Vehicle) ===
       Hairpin curve at ~1075m-1191m along edge #0 (total edge: 1627m).
       At t=12s (~step 120, vehicles accel from 13 to ~20 m/s):
         V003: ~1120m  (in/past the curve — brakes HERE)
         V002: ~1090m  (entering curve, relays V003's braking to V001)
         V001: ~1060m  (before curve — receives V2V warning, reacts)
       Relay path: V003->V002->V001 (1-2 hops, matches training topology)
       V001 cannot see V003 around the bend — pure V2V reaction. -->

  <!-- V003: Lead vehicle — emergency brakes in/past curve -->
  <vehicle id="V003" type="car" depart="0" route="convoy_route"
           departSpeed="13.000" departPos="752.000" departLane="0" color="1,0,0" />
  <!-- V002: Middle — relays V003's braking signal to ego -->
  <vehicle id="V002" type="car" depart="0" route="convoy_route"
           departSpeed="13.000" departPos="722.000" departLane="0" color="0,1,0" />
  <!-- V001: Ego vehicle (RL agent) — before curve, receives V2V warning -->
  <vehicle id="V001" type="car" depart="0" route="convoy_route"
           departSpeed="13.000" departPos="692.000" departLane="0" color="0,0,1" />
</routes>
